# ── Rust build artifacts ─────────────────────────────────────────────
/target/
**/*.rs.bk

# ── Python ───────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
.venv*/
env/
*.egg-info/
.pytest_cache/
.mypy_cache/

# ── Runtime / generated ──────────────────────────────────────────────
brain_log.txt
brain_stderr.log
crash.log
*.log

# ── Per-run learned state (regenerated at runtime; keep the seed
#    semantic_memory.json tracked, but not the volatile binary/JSON state) ──
*.npz
babble_*.json
working_memory_*.json
voice_esteem_*.json

# ── Environment ──────────────────────────────────────────────────────
.env
.env.local

# ── OS / editor cruft ────────────────────────────────────────────────
.DS_Store
*.swp
*.swo
.idea/
.vscode/
.claude/

# ── Models (downloaded on demand) ────────────────────────────────────
*.bin
*.pt
*.pth
*.onnx
models/
.cache/
